{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/(docs)/layout,_N_T_/(docs)/[[...slug]]/layout,_N_T_/(docs)/[[...slug]]/page,_N_T_/plugin-builders/specification"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/!KGRvY3Mp/$oc$slug/__PAGE__",
    "/!KGRvY3Mp/$oc$slug",
    "/!KGRvY3Mp",
    "/_index",
    "/_head"
  ]
}