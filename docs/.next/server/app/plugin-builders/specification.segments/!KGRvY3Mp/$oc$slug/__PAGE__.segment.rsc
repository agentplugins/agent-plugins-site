13:["$","ol",null,{"children":["\n",["$","li",null,{"children":["The metadata directory MUST contain only ",["$","code",null,{"children":"plugin.json"}],". All component directories (commands, agents, skills, rules, hooks) MUST be at the plugin root, not inside the metadata directory."]}],"\n",["$","li",null,{"children":"All paths within a plugin MUST be relative to the plugin root."}],"\n",["$","li",null,{"children":["All relative paths MUST start with ",["$","code",null,{"children":"./"}],"."]}],"\n",["$","li",null,{"children":["A plugin MUST NOT reference files outside its own directory tree via ",["$","code",null,{"children":"../"}]," traversal."]}],"\n"]}]
