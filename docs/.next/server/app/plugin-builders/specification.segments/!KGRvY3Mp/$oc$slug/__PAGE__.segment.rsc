17:["$","p",null,{"children":["Tools MUST check for the manifest in a metadata directory named with the pattern ",["$","code",null,{"children":".<tool-name>-plugin/plugin.json"}]," or ",["$","code",null,{"children":".plugin/plugin.json"}],". The vendor-neutral path ",["$","code",null,{"children":".plugin/plugin.json"}]," is RECOMMENDED for new plugins targeting multiple tools."]}]
18:["$","p",null,{"children":"For cross-tool compatibility, plugin authors MAY provide the manifest in multiple locations:"}]
